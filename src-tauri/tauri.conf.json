{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Angels NowPlaying",
  "version": "0.10.3",
  "identifier": "com.angelicadvocate.angelsnowplaying",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Angel's NowPlaying",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../dist/overlays": "overlays",
      "../dist/fonts": "fonts"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwNDhBQzdFNzRGN0YxRjkKUldUNThmZDBmcXhJVUJYWTQwUjZvME9RZ0d5Y29BVXMzbVZ5SzloK0c1SjZ5cXhHK2xreXFhVFkK",
      "endpoints": [
        "https://github.com/angelicadvocate/Angels-NowPlaying/releases/latest/download/latest.json"
      ]
    }
  }
}
